Xft.dpi: 96
Xft.antialias: true
Xft.rgba: rgb
Xft.hinting: true
Xft.autohint: true

URxvt.font: -misc-tamsyn-medium-r-normal--16-116-100-100-c-80-iso8859-1
URxvt.boldFont: -misc-tamsyn-bold-r-normal--16-116-100-100-c-80-iso8859-1
URxvt.italicFont: -misc-tamsyn-medium-r-normal--16-116-100-100-c-80-iso8859-1
URxvt.boldItalicFont: -misc-tamsyn-bold-r-normal--16-116-100-100-c-80-iso8859-1
URxvt.scrollBar: false
URxvt.letterSpace: 0
URxvt.internalBorder: 0
URxvt.externalBorder: 0
URxvt.borderless: 1

#define base00 #121212
#define base01 #bcbcbc
#define base02 #bcbcbc
#define base03 #5f5f87
#define base04 #bcbcbc
#define base05 #bcbcbc
#define base06 #bcbcbc
#define base07 #121212
#define base08 #bcbcbc
#define base09 #bcbcbc
#define base0A #bcbcbc
#define base0B #bcbcbc
#define base0C #bcbcbc
#define base0D #5f5f87
#define base0E #bcbcbc
#define base0F #bcbcbc

*foreground:   base05
*background:   base00
*cursorColor:  base05

*color0:       base00
*color1:       base08
*color2:       base0B
*color3:       base0A
*color4:       base0D
*color5:       base0E
*color6:       base0C
*color7:       base05

*color8:       base03
*color9:       base09
